# OpenAI (server-side only — use in API routes, never expose to the browser)
OPENAI_API_KEY=
# Optional override (defaults to gpt-4o)
# OPENAI_MODEL=gpt-4o

# Supabase (URL + anon key for client if needed; service role only on server)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional: server-only key for admin/seed scripts — never expose to client
SUPABASE_SERVICE_ROLE_KEY=

# Demo: in-transit ETA = tomorrow (UTC) on read. Default on in dev and on Netlify (NETLIFY=true). Set to 0/false/off to use raw DB dates only.
# BOOKLY_DEMO_RELATIVE_ORDER_DATES=false
